{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/wp-admin/:path*", "destination": "/404", "statusCode": 404 },
    { "source": "/wordpress/:path*", "destination": "/404", "statusCode": 404 },
    { "source": "/wp-login.php", "destination": "/404", "statusCode": 404 },
    { "source": "/wp-content/:path*", "destination": "/404", "statusCode": 404 },
    { "source": "/xmlrpc.php", "destination": "/404", "statusCode": 404 }
  ]
}
